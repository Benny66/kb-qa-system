# ── 复制此文件为 .env 并填入真实值 ───────────────────────────────────────────
# cp .env.example .env

# JWT 密钥（生产环境请替换为随机字符串，可用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# 智谱 AI 配置
# API Key 获取：https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# 模型选择：
#   glm-4-flash  —— 免费，速度快，推荐开发使用
#   glm-4-air    —— 性价比高
#   glm-4        —— 效果最强，按量计费
ZHIPUAI_MODEL=glm-4-flash

# 上传文件存储目录（相对于 app.py 的路径）
UPLOAD_FOLDER=uploads
