# ── Python 虚拟环境 ───────────────────────────────────────────────────────────
venv/
.venv/
env/
.env.bak

# ── 环境变量（含 API Key，绝对不能提交）─────────────────────────────────────
.env

# ── Python 编译缓存 ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ── SQLite 数据库（本地数据，不入库）────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── 用户上传的知识库文件（本地数据，不入库）─────────────────────────────────
uploads/*
!uploads/.gitkeep

# ── 日志 ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── 打包 / 分发 ───────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/

# ── 测试 & 覆盖率 ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
